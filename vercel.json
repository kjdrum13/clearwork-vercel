{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/adhd-productivity", "destination": "/adhd-productivity/index.html" },
    { "source": "/90-day-plan", "destination": "/90-day-plan/index.html" },
    { "source": "/vision-clarity", "destination": "/vision-clarity/index.html" },
    { "source": "/solopreneur-tools", "destination": "/solopreneur-tools/index.html" },
    { "source": "/too-many-ideas", "destination": "/too-many-ideas/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 30
    }
  }
}
